{
    "manifest_version": 3,
    "name": "My First Extension",
    "version": "1.0",
    "description": "A simple first extension",

    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],

    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],

    "action": {
      "default_popup": "popup.html",
      "default_icon": "icon.jpg"
    }
  }